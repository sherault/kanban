{
  "name": "kanban",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "dotenv -e .env -- turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\" --ignore-path .gitignore",
    "prepare": "husky"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "playwright": "^1.59.1",
    "prettier": "^3.3.3",
    "turbo": "^2.1.3",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "argon2",
      "better-sqlite3",
      "esbuild",
      "unrs-resolver"
    ],
    "overrides": {
      "esbuild@<=0.24.2": ">=0.25.0",
      "vite@<=6.4.1": ">=6.4.2",
      "hono@<4.12.12": ">=4.12.12",
      "drizzle-orm@<0.45.2": ">=0.45.2",
      "hono@>=4.0.0 <=4.12.11": ">=4.12.12",
      "@hono/node-server@<1.19.13": ">=1.19.13"
    }
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,json,md}": [
      "prettier --write"
    ],
    "**/*.{ts,tsx}": [
      "eslint --fix"
    ]
  }
}
