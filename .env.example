# API — auth secrets (required)
JWT_SECRET=change-me-in-production
REFRESH_SECRET=change-me-in-production

# API — app URL used in emails (required for email links to work)
APP_URL=http://localhost:3000

# API — SMTP (optional: if not set, verification URLs are logged to console)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com

# Web (public — exposed to browser)
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001
