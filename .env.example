# --- Database ---
DATABASE_URL=file:./data/kanban.db

# --- Auth Secrets ---
JWT_SECRET=super-secret-change-me
REFRESH_SECRET=another-secret-change-me

# --- API Configuration ---
# Internal port for the API server
PORT=3001
# Public URL for the WEB Frontend (used for email links, CSRF, and CORS)
APP_URL=http://localhost:3000
# Base URL for the API (server-side calls)
# Use http://api:3001 in Docker, http://localhost:3010 in local dev
API_URL=http://localhost:3010

# --- Security ---
# Set to 'true' to force HSTS, 'false' to disable it even in production.
# Defaults to true when NODE_ENV=production.
ENABLE_HSTS=false

# --- Web Configuration ---
# Public URL for WebSockets (browser-side connection)
NEXT_PUBLIC_WS_URL=ws://localhost:3010

# --- Email (Optional) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com
